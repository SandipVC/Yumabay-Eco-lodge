PORT=3001

# SMTP settings (use a real provider in production: SendGrid, Mailgun, Gmail, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email addresses
FROM_EMAIL=info@yumabay.com
FROM_NAME=Yuma Bay Eco Lodge
TEAM_EMAIL=team@yumabay.com

# Client origin for CORS (no trailing slash)
CLIENT_ORIGIN=http://localhost:5173

# Secret key for admin dashboard access
ADMIN_SECRET=change-this-secret-key
